{
  "compilerOptions": {
    "target": "ES2015",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2015"
    ],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "composite": true,
    "rootDir": "src",
    "outDir": "dist",
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  }
}
