{
  "name": "@jscrypto/monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Composable cryptography components for JavaScript and TypeScript.",
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/classic"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "clean": "tsc -b --clean && node scripts/clean.mjs",
    "typecheck": "tsc -b --pretty false",
    "test": "npm run build && npm run test:dist",
    "test:dist": "node --test tests/*.test.mjs",
    "coverage": "npm run build && npm run coverage:dist",
    "coverage:dist": "c8 --check-coverage --statements 100 --branches 100 --functions 100 --lines 100 --reporter=text --reporter=html --reporter=lcov --include=packages/core/dist/index.mjs --include=packages/classic/dist/index.mjs --include=packages/classic/dist/hashes.mjs node --test tests/*.test.mjs",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "c8": "^11.0.0",
    "rollup": "^4.62.2",
    "typescript": "^5.5.0"
  },
  "license": "MIT"
}
