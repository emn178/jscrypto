{
  "name": "@jscrypto/classic",
  "version": "0.6.0",
  "description": "Classic cipher, mode, padding, KDF, and format components for @jscrypto.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./hashes": {
      "types": "./dist/hashes-entry.d.ts",
      "import": "./dist/hashes.mjs",
      "require": "./dist/hashes.cjs"
    },
    "./browser": "./dist/jscrypto-classic.iife.min.js",
    "./hashes/browser": "./dist/jscrypto-classic-hashes.iife.min.js",
    "./umd": "./dist/jscrypto-classic.umd.min.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@jscrypto/core": "0.5.1",
    "js-md5": "^0.8.3",
    "js-sha1": "^0.7.0",
    "js-sha256": "^0.11.1",
    "js-sha3": "^0.9.3",
    "js-sha512": "^0.9.0"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "keywords": [
    "crypto",
    "cryptography",
    "cipher",
    "aes",
    "des",
    "rc4"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emn178/jscrypto.git",
    "directory": "packages/classic"
  },
  "bugs": {
    "url": "https://github.com/emn178/jscrypto/issues"
  },
  "homepage": "https://github.com/emn178/jscrypto#readme",
  "author": "Chen, Yi-Cyuan <emn178@gmail.com>",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "license": "MIT"
}
